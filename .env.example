# Generate a key at https://cut.pro/studio/me/api-keys (API access requires the Pro plan)
CUTPRO_API_KEY=

# Only needed for multi-workspace keys
# CUTPRO_WORKSPACE_ID=

# Override the API base URL (defaults to https://api.cut.pro/api/v1)
# CUTPRO_API_URL=https://api.cut.pro/api/v1

# Remote transport (self-host). Set either of these to serve Streamable HTTP at /mcp
# instead of stdio. In HTTP mode the key is read per request from the
# Authorization: Bearer / X-Api-Key header (the env key is the fallback).
# MCP_TRANSPORT=http
# PORT=8787

# OAuth 2.1 (for browser clients: ChatGPT connectors, Claude.ai). Requires HTTP mode.
# Users authorize by pasting their CutPro API key on a consent page; the issued
# token maps to that key. MCP_PUBLIC_URL must be the server's public https URL.
# MCP_OAUTH=1
# MCP_PUBLIC_URL=https://mcp.cut.pro

# Back the OAuth state (clients, codes, tokens) with Redis so it survives restarts
# and works across multiple instances. Without it, an in-memory store is used.
# MCP_REDIS_URL=redis://127.0.0.1:6379
