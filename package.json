{
	"name": "@cutpro/mcp",
	"version": "1.0.2",
	"mcpName": "io.github.getcutpro/cutpro",
	"description": "CutPro MCP server — wraps the public v1 API as MCP tools for AI clients",
	"author": "Lucas Toledo",
	"license": "MIT",
	"type": "module",
	"packageManager": "bun@1.3.14",
	"keywords": [
		"mcp",
		"model-context-protocol",
		"cutpro",
		"ai",
		"clipping"
	],
	"homepage": "https://cut.pro/docs/api-reference/mcp",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/getcutpro/mcp.git"
	},
	"bugs": {
		"url": "https://github.com/getcutpro/mcp/issues"
	},
	"bin": {
		"cutpro-mcp": "dist/index.js"
	},
	"files": [
		"dist"
	],
	"engines": {
		"node": ">=18"
	},
	"publishConfig": {
		"access": "public"
	},
	"scripts": {
		"dev": "bun run src/index.ts",
		"start": "node dist/index.js",
		"start:http": "MCP_TRANSPORT=http node dist/index.js",
		"build": "rm -rf dist && bun build src/index.ts --outdir dist --target node --minify",
		"typecheck": "bun x tsc --noEmit",
		"prepublishOnly": "bun run build"
	},
	"dependencies": {
		"@modelcontextprotocol/sdk": "^1.29.0",
		"express": "^5.2.1",
		"ioredis": "^5.4.0",
		"zod": "^4.0.0"
	},
	"devDependencies": {
		"@types/bun": "^1.2.0",
		"@types/express": "^5.0.0",
		"@types/node": "^22.0.0",
		"typescript": "^5.6.0"
	}
}
